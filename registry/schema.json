{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ducktape-ui:registry:v1",
  "title": "ducktape-ui registry",
  "type": "object",
  "required": ["name", "version", "items"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "const": 1 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "description", "files"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "type": { "enum": ["theme", "component", "block"] },
          "description": { "type": "string" },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "cargoDependencies": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["source", "target"],
              "properties": {
                "source": { "type": "string" },
                "target": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
